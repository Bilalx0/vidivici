

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  password      String
  role          Role       @default(USER)
  phone         String?
  image         String?
  dateOfBirth   String?
  company       String?
  address       String?
  country       String?
  city          String?
  state         String?
  zipCode       String?
  driverLicense       String?
  driverLicenseStatus String  @default("NONE")
  insurance           String?
  insuranceStatus     String  @default("NONE")
  passport            String?
  passportStatus      String  @default("NONE")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  bookings      Booking[]
  wishlist      Wishlist[]
  villaBookings VillaBooking[]
  chatSessions  ChatSession[]
}

enum Role {
  USER
  ADMIN
}

model Wishlist {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId     String
  createdAt DateTime @default(now())

  @@unique([userId, carId])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cars        Car[]
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  logo        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cars        Car[]
}

model Car {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  brand            Brand      @relation(fields: [brandId], references: [id])
  brandId          String
  category         Category   @relation(fields: [categoryId], references: [id])
  categoryId       String
  description      String?    @db.Text
  shortDescription String?
  detailHeading    String?
  pricePerDay      Float
  originalPrice    Float?
  year             Int?
  seats            Int        @default(4)
  transmission     String     @default("Automatic")
  fuelType         String     @default("Gasoline")
  horsepower       Int?
  topSpeed         String?
  acceleration     String?
  milesIncluded    Int        @default(100)
  extraMileRate    Float      @default(9.0)
  minRentalDays    Int        @default(1)
  isAvailable      Boolean    @default(true)
  isFeatured       Boolean    @default(false)
  location         String     @default("Los Angeles")
  images           CarImage[]
  bookings         Booking[]
  wishlist         Wishlist[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model CarImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId     String
  createdAt DateTime @default(now())
}

model Booking {
  id              String        @id @default(cuid())
  bookingNumber   String        @unique @default(cuid())
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  car             Car           @relation(fields: [carId], references: [id])
  carId           String
  startDate       DateTime
  endDate         DateTime
  startTime       String?
  endTime         String?
  pickupLocation  String
  dropoffLocation String
  deliveryType    String        @default("pickup")
  deliveryAddress String?
  returnAddress   String?
  isOneWay        Boolean       @default(false)
  needsDriver     Boolean       @default(false)
  driverHours     Int?
  driverDays      Int?
  deliveryFee     Float         @default(0)
  driverCost      Float         @default(0)
  discount        Float         @default(0)
  addOnsTotal     Float         @default(0)
  tax             Float         @default(0)
  basePrice       Float         @default(0)
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  documentStatus  String        @default("PENDING")
  paymentIntentId       String?
  paypalOrderId         String?
  paypalAuthorizationId String?
  contractStatus        String        @default("NONE")
  contractSentAt        DateTime?
  notes                 String?       @db.Text
  adminNotes            String?       @db.Text
  documents             String?       @db.Text
  source                String        @default("website")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String   @db.Text
  excerpt    String?
  coverImage String?
  category   String   @default("News & Updates")
  published  Boolean  @default(false)
  author     String   @default("Vidi Vici")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  content   String   @db.Text
  rating    Int      @default(5)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Inquiry {
  id          String   @id @default(cuid())
  source      String   // "car", "villa", "event", "general", "partner", "production", "wedding"
  category    String   // "Car", "Villa", "Event", "General"
  name        String
  email       String
  phone       String?
  subject     String?
  message     String?  @db.Text
  data        String?  @db.Text // JSON string for extra form fields
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ChatSession {
  id          String        @id @default(cuid())
  visitorId   String
  visitorName String?
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  isPaused    Boolean       @default(false)
  lastMessage String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user", "assistant", "admin"
  content   String      @db.Text
  createdAt DateTime    @default(now())
}

model SiteSettings {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String  @db.Text
  description String?
}

model Villa {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  description      String?      @db.Text
  shortDescription String?
  detailHeading    String?
  location         String       @default("Los Angeles")
  address          String?
  bedrooms         Int          @default(4)
  bathrooms        Int          @default(3)
  guests           Int          @default(8)
  sqft             Int          @default(4800)
  pricePerNight    Float
  cleaningFee      Float        @default(0)
  securityDeposit  Float        @default(0)
  amenities        String?      @db.Text
  isAvailable      Boolean      @default(true)
  isFeatured       Boolean      @default(false)
  images           VillaImage[]
  villaBookings    VillaBooking[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model VillaImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  villa     Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)
  villaId   String
  createdAt DateTime @default(now())
}

model VillaBooking {
  id              String        @id @default(cuid())
  bookingNumber   String        @unique @default(cuid())
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  villa           Villa         @relation(fields: [villaId], references: [id])
  villaId         String
  checkIn         DateTime
  checkOut        DateTime
  guests          Int           @default(1)
  totalPrice            Float
  status                BookingStatus @default(PENDING)
  paymentStatus         PaymentStatus @default(UNPAID)
  documentStatus        String        @default("PENDING")
  paypalOrderId         String?
  paypalAuthorizationId String?
  contractStatus        String        @default("NONE")
  contractSentAt        DateTime?
  notes                 String?       @db.Text
  adminNotes            String?       @db.Text
  documents             String?       @db.Text
  source                String        @default("website")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model WeddingInquiry {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String?
  email          String
  phone          String?
  eventType      String
  eventDate      DateTime
  guestCount     Int      @default(50)
  addOns         String?
  specialRequests String? @db.Text
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Event {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  description      String?        @db.Text
  shortDescription String?
  location         String         @default("Los Angeles")
  address          String?
  category         String         @default("Nightlife")
  venueName        String?
  capacity         Int            @default(200)
  priceRange       String?
  dressCode        String?
  highlights       String?        @db.Text
  experience       String?        @db.Text
  isAvailable      Boolean        @default(true)
  isFeatured       Boolean        @default(false)
  images           EventImage[]
  bookings         EventBooking[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model EventImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  createdAt DateTime @default(now())
}

model EventBooking {
  id              String   @id @default(cuid())
  bookingNumber   String?  @unique
  event           Event?   @relation(fields: [eventId], references: [id])
  eventId         String?
  firstName       String
  lastName        String?
  email           String
  phone           String?
  clubVenue       String?
  bookingDate     DateTime
  guestsTotal     String?
  budget          String?
  addOns          String?
  specialRequests String?  @db.Text
  totalPrice            Float    @default(0)
  status                String   @default("PENDING")
  paymentStatus         String   @default("UNPAID")
  documentStatus        String   @default("PENDING")
  paypalOrderId         String?
  paypalAuthorizationId String?
  contractStatus        String   @default("NONE")
  contractSentAt        DateTime?
  adminNotes            String?  @db.Text
  documents             String?  @db.Text
  source                String   @default("website")
  isRead                Boolean  @default(false)
  createdAt             DateTime @default(now())
}
